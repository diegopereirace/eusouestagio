<section class="custom-error-page" aria-live="polite">
  <div class="custom-error-page__panel">
    <div class="custom-error-page__code">Erro {{ status_code }}</div>
    <div class="custom-error-page__icon" aria-hidden="true">
      <i class="{{ icon }}"></i>
    </div>
    <h1 class="custom-error-page__title">{{ title }}</h1>
    <p class="custom-error-page__message">{{ message }}</p>
    <p class="custom-error-page__hint">{{ hint }}</p>
  </div>
</section>
