{#
/**
 * @file
 * Painel do moderador: listagem de todas as candidaturas com controle de status.
 *
 * Variables:
 * - rows: Array de candidaturas, cada uma com:
 *     candidatura_nid, candidato_nome, candidato_email, candidato_url,
 *     vaga_titulo, vaga_url, data, status_key, status_label.
 * - empty: Mensagem quando não há candidaturas.
 * - status_options: Objeto {chave: label} de todos os status disponíveis.
 * - update_url: Endpoint POST para atualização de status.
 */
#}
<div class="moderador-candidaturas pt-3 pb-5">
  {% if rows is not empty %}
    <div class="card">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-striped table-hover mb-0 align-middle"
                 data-update-url="{{ update_url }}">
            <thead>
              <tr>
                <th class="px-3 py-3 text-muted text-nowrap" style="width:1%">#</th>
                <th class="px-3 py-3">{{ 'Candidato'|t }}</th>
                <th class="px-3 py-3">{{ 'E-mail'|t }}</th>
                <th class="px-3 py-3">{{ 'Vaga'|t }}</th>
                <th class="px-3 py-3 text-nowrap">{{ 'Data'|t }}</th>
                <th class="px-3 py-3 text-nowrap">{{ 'Status'|t }}</th>
                <th class="px-3 py-3">{{ 'Ação'|t }}</th>
              </tr>
            </thead>
            <tbody>
              {% for row in rows %}
                <tr data-nid="{{ row.candidatura_nid }}">
                  <td class="px-3 py-2 text-muted small">{{ loop.index }}</td>
                  <td class="px-3 py-2">
                    {% if row.candidato_url %}
                      <a href="{{ row.candidato_url }}" target="_blank">{{ row.candidato_nome }}</a>
                    {% else %}
                      {{ row.candidato_nome }}
                    {% endif %}
                  </td>
                  <td class="px-3 py-2 small text-muted">{{ row.candidato_email }}</td>
                  <td class="px-3 py-2">
                    {% if row.vaga_url %}
                      <a href="{{ row.vaga_url }}" target="_blank">{{ row.vaga_titulo }}</a>
                    {% else %}
                      {{ row.vaga_titulo }}
                    {% endif %}
                  </td>
                  <td class="px-3 py-2 text-nowrap text-muted small">{{ row.data }}</td>
                  <td class="px-3 py-2 text-nowrap">
                    <span class="badge candidatura-status-badge candidatura-status--{{ row.status_key }}">
                      {{ row.status_label }}
                    </span>
                  </td>
                  <td class="px-3 py-2">
                    <div class="d-flex gap-2 align-items-center flex-nowrap">
                      <select class="form-select form-select-sm js-status-select" style="min-width:160px">
                        {% for key, label in status_options %}
                          <option value="{{ key }}"{% if key == row.status_key %} selected{% endif %}>
                            {{ label }}
                          </option>
                        {% endfor %}
                      </select>
                      <button type="button"
                              class="btn btn-sm btn-primary js-salvar-status text-nowrap"
                              data-nid="{{ row.candidatura_nid }}">
                        {{ 'Salvar'|t }}
                      </button>
                    </div>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  {% else %}
    <div class="card">
      <div class="card-body text-center py-5">
        <i class="fa-regular fa-inbox fa-3x text-muted mb-3 d-block"></i>
        <p class="text-muted mb-0">{{ empty }}</p>
      </div>
    </div>
  {% endif %}
</div>
