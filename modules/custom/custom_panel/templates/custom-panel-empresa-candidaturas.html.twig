{#
/**
 * @file
 * Painel da empresa: candidaturas recebidas nas suas vagas (somente leitura).
 *
 * Variables:
 * - rows: Array de candidaturas, cada uma com:
 *     candidato_nome, candidato_email, vaga_titulo, vaga_url, data, status_key, status_label.
 * - empty: Mensagem quando não há candidaturas.
 */
#}
<div class="empresa-candidaturas pt-3 pb-5">
  {% if rows is not empty %}
    <div class="card">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-striped table-hover mb-0 align-middle">
            <thead>
              <tr>
                <th class="px-4 py-3 text-muted text-nowrap" style="width:1%">#</th>
                <th class="px-4 py-3">{{ 'Candidato'|t }}</th>
                <th class="px-4 py-3">{{ 'E-mail'|t }}</th>
                <th class="px-4 py-3">{{ 'Vaga'|t }}</th>
                <th class="px-4 py-3 text-nowrap">{{ 'Data da Candidatura'|t }}</th>
                <th class="px-4 py-3 text-nowrap">{{ 'Status'|t }}</th>
              </tr>
            </thead>
            <tbody>
              {% for row in rows %}
                <tr>
                  <td class="px-4 py-2 text-muted small">{{ loop.index }}</td>
                  <td class="px-4 py-2">{{ row.candidato_nome }}</td>
                  <td class="px-4 py-2 small text-muted">{{ row.candidato_email }}</td>
                  <td class="px-4 py-2">
                    {% if row.vaga_url %}
                      <a href="{{ row.vaga_url }}" target="_blank">{{ row.vaga_titulo }}</a>
                    {% else %}
                      {{ row.vaga_titulo }}
                    {% endif %}
                  </td>
                  <td class="px-4 py-2 text-nowrap text-muted small">{{ row.data }}</td>
                  <td class="px-4 py-2 text-nowrap">
                    <span class="badge candidatura-status--{{ row.status_key }}">
                      {{ row.status_label }}
                    </span>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  {% else %}
    <div class="card">
      <div class="card-body text-center py-5">
        <i class="fa-regular fa-inbox fa-3x text-muted mb-3 d-block"></i>
        <p class="text-muted mb-3">{{ empty }}</p>
        <a href="/vagas" class="btn btn-primary btn-sm">{{ 'Ver Vagas'|t }}</a>
      </div>
    </div>
  {% endif %}
</div>
