<?php

use Drupal\Component\Utility\Html;
use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_theme().
 */
function custom_configs_users_theme(): array {
    return [
        'candidato_perfil' => [
            'variables' => [
                'dados'        => [],
                'instituicoes' => [],
                'cursos'       => [],
                'experiencias' => [],
                'user'         => NULL,
            ],
        ],
        'empresa_perfil' => [
            'variables' => [
                'dados' => [],
                'user'  => NULL,
            ],
        ],
    ];
}

/**
 * Implements hook_form_user_form_alter().
 */
function custom_configs_users_form_user_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
    $pass_reset_token = \Drupal::request()->query->get('pass-reset-token');
    $translation = \Drupal::translation();

    if (!$pass_reset_token) {
        return;
    }

    $allowed_top_level = [
        'account',
        'actions',
        'form_build_id',
        'form_token',
        'form_id',
        'op',
        '#attributes',
        '#cache',
        '#theme',
        '#attached',
        '#tree',
        '#parents',
        '#submit',
        '#validate',
        '#method',
        '#action',
        '#token',
        '#id',
    ];

    foreach ($form as $key => &$element) {
        if (strpos((string) $key, '#') === 0) {
            continue;
        }

        if (is_array($element) && (($element['#type'] ?? NULL) === 'hidden')) {
            continue;
        }

        if (!in_array($key, $allowed_top_level, TRUE)) {
            $element['#access'] = FALSE;
        }
    }

    if (isset($form['account']) && is_array($form['account'])) {
        foreach ($form['account'] as $key => &$element) {
            if (strpos((string) $key, '#') === 0) {
                continue;
            }

            if ($key !== 'pass') {
                $element['#access'] = FALSE;
            }
        }

        $form['account']['reset_help'] = [
            '#type' => 'markup',
            '#markup' => '<div class="alert alert-info mb-3">' . $translation->translate('Defina uma nova senha para concluir o acesso da sua conta.') . '</div>',
            '#weight' => -100,
        ];
    }

    if (isset($form['actions']['submit'])) {
        $form['actions']['submit']['#value'] = $translation->translate('Definir senha');
        $form['actions']['submit']['#submit'][] = 'custom_configs_users_user_pass_reset_submit';
    }
}

/**
 * Submit callback for password reset with token.
 */
function custom_configs_users_user_pass_reset_submit(array &$form, FormStateInterface $form_state) {
    $pass_reset_token = \Drupal::request()->query->get('pass-reset-token');

    if (!$pass_reset_token) {
        return;
    }

    $account = \Drupal::routeMatch()->getParameter('user');
    if (is_numeric($account)) {
        $account = \Drupal\user\Entity\User::load($account);
    }

    \Drupal::messenger()->addStatus(\Drupal::translation()->translate('Senha definida com sucesso. Bem-vindo(a)!'));

    if ($account && method_exists($account, 'hasRole') && $account->hasRole('empresa')) {
        $form_state->setRedirect('custom_configs_users.empresa_perfil');
        return;
    }

    if ($account && method_exists($account, 'hasRole') && $account->hasRole('candidato')) {
        $form_state->setRedirect('custom_configs_users.candidato_perfil');
        return;
    }

    $form_state->setRedirect('<front>');
}

/**
 * Implements hook_mail_alter().
 */
function custom_configs_users_mail_alter(array &$message) {
    $target_keys = [
        'register_no_approval_required',
        'register_pending_approval',
        'password_reset',
    ];

    if (($message['module'] ?? '') !== 'user' || !in_array(($message['key'] ?? ''), $target_keys, TRUE)) {
        return;
    }

    $raw_body = implode("\n", array_map('strval', (array) ($message['body'] ?? [])));
    $cta_url = custom_configs_users_extract_first_url($raw_body);

    $site_name = (string) \Drupal::config('system.site')->get('name');
    $account_name = '';
    if (!empty($message['params']['account']) && is_object($message['params']['account']) && method_exists($message['params']['account'], 'getAccountName')) {
        $account_name = (string) $message['params']['account']->getAccountName();
    }

    $title = 'Atualizacao de acesso';
    $intro = 'Confira as instrucoes abaixo para continuar.';

    switch ($message['key']) {
        case 'register_no_approval_required':
            $title = 'Confirme seu acesso';
            $intro = 'Sua conta foi criada. Para concluir o acesso, defina sua senha pelo botao abaixo.';
            break;

        case 'password_reset':
            $title = 'Redefinicao de senha';
            $intro = 'Recebemos uma solicitacao para redefinir sua senha. Use o botao abaixo para continuar.';
            break;

        case 'register_pending_approval':
            $title = 'Cadastro recebido';
            $intro = 'Seu cadastro foi recebido e esta aguardando aprovacao.';
            break;
    }

    $html = custom_configs_users_build_mail_html($title, $intro, $cta_url, $account_name, $site_name);

    $message['headers']['MIME-Version'] = '1.0';
    $message['headers']['Content-Type'] = 'text/html; charset=UTF-8; format=flowed; delsp=yes';
    $message['headers']['Content-Transfer-Encoding'] = '8Bit';
    $message['body'] = [$html];
}

/**
 * Extrai a primeira URL de um texto.
 */
function custom_configs_users_extract_first_url(string $text): string {
    if (preg_match('/https?:\/\/[^\s<>"\']+/i', $text, $matches)) {
        return rtrim($matches[0], '.,);');
    }

    return '';
}

/**
 * Monta HTML de e-mail com estilo inline (sem imagens).
 */
function custom_configs_users_build_mail_html(string $title, string $intro, string $cta_url, string $account_name, string $site_name): string {
    $title_safe = Html::escape($title);
    $intro_safe = Html::escape($intro);
    $site_safe = Html::escape($site_name !== '' ? $site_name : 'Eu Sou Estagio');
    $account_safe = Html::escape($account_name);

    $hello = $account_safe !== '' ? "Ola, {$account_safe}." : 'Ola,';
    $hello_safe = Html::escape($hello);

    $button_html = '';
    if ($cta_url !== '') {
        $cta_safe = Html::escape($cta_url);
        $button_html = '<tr><td style="padding:0 32px 28px 32px;">'
            . '<a href="' . $cta_safe . '" style="display:inline-block;background:#e67e22;color:#ffffff;text-decoration:none;font-weight:700;padding:12px 22px;border-radius:6px;">Continuar</a>'
            . '</td></tr>'
            . '<tr><td style="padding:0 32px 18px 32px;font-size:13px;line-height:1.5;color:#5a6473;">'
            . 'Se o botao nao funcionar, copie e cole este link no navegador:<br>'
            . '<span style="word-break:break-all;color:#0b4a74;">' . $cta_safe . '</span>'
            . '</td></tr>';
    }
    else {
        $button_html = '<tr><td style="padding:0 32px 20px 32px;font-size:14px;line-height:1.6;color:#5a6473;">'
            . 'Nenhuma acao adicional e necessaria neste momento. Aguarde novas instrucoes por e-mail.'
            . '</td></tr>';
    }

    return '<!doctype html>'
        . '<html><body style="margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;color:#1d2430;">'
        . '<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f4f7fb;padding:20px 0;">'
        . '<tr><td align="center">'
        . '<table role="presentation" width="620" cellpadding="0" cellspacing="0" style="max-width:620px;width:100%;background:#ffffff;border-radius:8px;overflow:hidden;border-top:6px solid #0b4a74;">'
        . '<tr><td style="padding:26px 32px 6px 32px;font-size:24px;line-height:1.2;font-weight:700;color:#0b4a74;">' . $site_safe . '</td></tr>'
        . '<tr><td style="padding:0 32px 8px 32px;font-size:20px;line-height:1.3;font-weight:700;color:#1d2430;">' . $title_safe . '</td></tr>'
        . '<tr><td style="padding:4px 32px 14px 32px;font-size:15px;line-height:1.6;color:#2b3445;">' . $hello_safe . '</td></tr>'
        . '<tr><td style="padding:0 32px 22px 32px;font-size:15px;line-height:1.7;color:#2b3445;">' . $intro_safe . '</td></tr>'
        . $button_html
        . '<tr><td style="padding:18px 32px 26px 32px;border-top:1px solid #e8edf3;font-size:12px;line-height:1.6;color:#6f7a8a;">'
        . 'Este e-mail foi enviado por ' . $site_safe . '.'
        . '</td></tr>'
        . '</table>'
        . '</td></tr></table>'
        . '</body></html>';
}
