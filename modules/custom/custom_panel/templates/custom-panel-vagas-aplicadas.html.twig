{#
/**
 * @file
 * Listagem de vagas às quais o estudante se candidatou.
 *
 * Variables:
 * - rows: Array de candidaturas, cada uma com 'title', 'url', 'date', 'status' e 'status_key'.
 * - empty: Mensagem exibida quando não há candidaturas.
 */
#}
<div class="vagas-aplicadas pt-3 pb-5">
  {% if rows is not empty %}
    <div class="card">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-striped table-hover mb-0">
            <thead>
              <tr>
                <th class="px-4 py-3 text-muted text-nowrap" style="width:1%">#</th>
                <th class="px-4 py-3">{{ 'Vaga'|t }}</th>
                <th class="px-4 py-3 text-nowrap">{{ 'Status'|t }}</th>
                <th class="px-4 py-3 text-nowrap">{{ 'Data de Candidatura'|t }}</th>
              </tr>
            </thead>
            <tbody>
              {% for row in rows %}
                <tr>
                  <td class="px-4 py-2 text-muted small text-nowrap align-middle">{{ loop.index }}</td>
                  <td class="px-4 py-2 align-middle">
                    <a href="{{ row.url }}" target="_blank">{{ row.title }}</a>
                  </td>
                  <td class="px-4 py-2 align-middle text-nowrap">
                    <span class="badge candidatura-status--{{ row.status_key }}">{{ row.status }}</span>
                  </td>
                  <td class="px-4 py-2 text-nowrap text-muted small align-middle">{{ row.date }}</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  {% else %}
    <div class="card">
      <div class="card-body text-center py-5">
        <i class="fa-regular fa-paper-plane fa-3x text-muted mb-3 d-block"></i>
        <p class="text-muted mb-3">{{ empty }}</p>
        <a href="/vagas" class="btn btn-primary btn-sm">{{ 'Buscar Vagas'|t }}</a>
      </div>
    </div>
  {% endif %}
</div>

