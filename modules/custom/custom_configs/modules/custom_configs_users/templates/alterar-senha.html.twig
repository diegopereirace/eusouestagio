{#
/**
 * @file
 * Template da página de alteração de senha.
 *
 * Variáveis:
 *   - form: render array do formulário AlterarSenhaForm.
 *   - user: entidade User atual.
 */
#}

<div class="alterar-senha-page container py-4">

  {# ── Cabeçalho ──────────────────────────────────────────── #}
  <div class="mb-4">
    <h2 class="mb-1"><i class="fas fa-lock me-2"></i>{{ 'Alterar Senha'|t }}</h2>
    <p class="text-muted mb-0">{{ 'Preencha os campos abaixo para definir uma nova senha.'|t }}</p>
  </div>

  {# ── Formulário ──────────────────────────────────────────── #}
  <div class="card shadow-sm" style="max-width: 500px;">
    <div class="card-body p-4">
      {{ form }}
    </div>
  </div>

</div>
