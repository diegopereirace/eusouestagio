<div class="item-vaga">
    <div class="item-inner">
        <div class="row-custom row-1 d-flex justify-content-between">
            <div class="col-custom">
                <h3 class="text-title-xs me-3">{{ row._entity.title.value }}</h3>
                {% if row._entity.field_text_simple_2.value is not empty %}
                    <div class="dv-empresa">{{ row._entity.field_text_simple_2.value }}</div>
                {% endif %}
            </div>
            <div class="col-custom">
                {% if row._entity.field_regime_t is not empty %}
                    {% set regime_labels = [] %}
                    {% for item in row._entity.field_regime_t %}
                        {% if item.entity %}
                            {% set regime_labels = regime_labels|merge([item.entity.label]) %}
                        {% endif %}
                    {% endfor %}
                    {% if regime_labels is not empty %}
                        <div class="item-regime">{{ regime_labels|join(', ') }}</div>
                    {% endif %}
                {% endif %}
            </div>
        </div>
        <div class="row-custom row-2">
            <div class="col-custom d-flex text-align-center pb-3">
                {% if row._entity.field_text_simple.value is not empty %}
                    <i class="fa-solid fa-dollar-sign"></i>
                    <div class="dv-salario">{{ row._entity.field_text_simple.value }}</div>
                {% endif %}
            </div>
            {% set bairro = row._entity.field_bairro.value ?? '' %}
            {% set cidade = row._entity.field_cidade.value %}
            {% set estado = row._entity.field_estados.value %}
            {% if bairro or cidade or estado %}
            <div class="col-custom d-flex align-items-center gap-1 pb-3 text-muted small">
                <i class="fa-solid fa-location-dot"></i>
                <span class="dv-localizacao">
                    {%- if bairro and cidade and estado -%}
                        {{ bairro }} – {{ cidade }} – {{ estado }}
                    {%- elseif bairro and cidade -%}
                        {{ bairro }} – {{ cidade }}
                    {%- elseif bairro and estado -%}
                        {{ bairro }} – {{ estado }}
                    {%- elseif cidade and estado -%}
                        {{ cidade }} – {{ estado }}
                    {%- elseif bairro -%}
                        {{ bairro }}
                    {%- elseif cidade -%}
                        {{ cidade }}
                    {%- else -%}
                        {{ estado }}
                    {%- endif -%}
                </span>
            </div>
            {% endif %}
            <div class="col-custom d-flex text-align-center">
                {% set cursos_items = row._entity.field_cursos_t is defined and row._entity.field_cursos_t is not empty
                    ? row._entity.field_cursos_t
                    : (row._entity.field_tecnologias_t is defined and row._entity.field_tecnologias_t is not empty ? row._entity.field_tecnologias_t : []) %}
                {% if cursos_items is not empty %}
                    <div class="tag-list">
                        {% for item in cursos_items|slice(0, 2) %}
                            {% if item.entity %}
                                <span class="tag-pill">{{ item.entity.label }}</span>
                            {% endif %}
                        {% endfor %}
                        {% if cursos_items|length > 2 %}
                            <span class="tag-pill tag-pill--more">...</span>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>
        <div class="vaga-numero">{{ 'Número da Vaga:'|t }} {{ row._entity.id }}</div>
        <div class="row-custom row-3">
            <a href="{{ path('entity.node.canonical', {'node': row._entity.id}) }}" class="ui-btn ui-btn--primary w-100">{{ 'Ver Detalhes'|t }}</a>
        </div>
    </div>
</div>