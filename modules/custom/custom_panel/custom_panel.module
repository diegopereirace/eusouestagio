<?php

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\views\Plugin\views\query\Sql;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_form_user_login_form_alter().
 *
 * Adiciona submit handler para redirecionar ao painel após login.
 */
function custom_panel_form_user_login_form_alter(array &$form, FormStateInterface $form_state, $form_id)
{
    $form['#submit'][] = '_custom_panel_login_redirect';
}

/**
 * Submit handler: redireciona o usuário para /painel após login.
 */
function _custom_panel_login_redirect(array &$form, FormStateInterface $form_state)
{
    // Não sobrescreve se já existe um destination na query string.
    $destination = \Drupal::request()->query->get('destination');
    if (!empty($destination)) {
        return;
    }

    $user = \Drupal\user\Entity\User::load(\Drupal::currentUser()->id());
    if (!$user) {
        return;
    }

    // Redireciona conforme o papel do usuário.
    if ($user->hasRole('candidato')) {
        $form_state->setRedirect('custom_panel.painel_estudante_perfil');
    } elseif ($user->hasRole('empresa')) {
        $form_state->setRedirect('custom_panel.painel_empresa_perfil');
    } elseif ($user->hasRole('moderador')) {
        $form_state->setRedirect('custom_panel.moderador_candidaturas_listagem');
    }
}

/**
 * Implements hook_form_node_form_alter().
 *
 * Exibe o número da vaga como campo somente leitura no formulário.
 */
function custom_panel_form_node_form_alter(array &$form, FormStateInterface $form_state, $form_id): void
{
    $form_object = $form_state->getFormObject();
    if (!$form_object || !method_exists($form_object, 'getEntity')) {
        return;
    }

    $node = $form_object->getEntity();
    if (!$node || $node->bundle() !== 'vagas') {
        return;
    }

    $is_new = $node->isNew();
    $numero_vaga = $is_new ? (string) t('Será gerado ao salvar') : (string) $node->id();
    $descricao = $is_new
        ? t('Este número é criado automaticamente no momento do cadastro e não pode ser previsto antes do salvamento. Após salvar, ele ficará visível para consulta e busca.')
        : t('Este é o identificador interno da vaga. O valor é gerado automaticamente e não pode ser alterado.');

    $form['numero_vaga_info'] = [
        '#type' => 'textfield',
        '#title' => t('Número da Vaga'),
        '#default_value' => $numero_vaga,
        '#description' => $descricao,
        '#disabled' => TRUE,
        '#attributes' => [
            'readonly' => 'readonly',
        ],
        '#weight' => -90,
    ];
}

/**
 * Implements hook_preprocess_page().
 *
 * Usa um container em largura total apenas nas URLs do painel para ampliar
 * a área útil das listagens.
 */
/**
 * Implements hook_form_views_exposed_form_alter().
 *
 * Ajusta o filtro exposto de cursos da view de vagas para funcionar como
 * campo de texto livre, sem exigir seleção do autocomplete.
 */
function custom_panel_form_views_exposed_form_alter(array &$form, FormStateInterface $form_state, $form_id): void
{
    $view = $form['#view'] ?? $form_state->get('view');
    $form_dom_id = (string) ($form['#id'] ?? '');
    $is_vagas_form = ($view instanceof ViewExecutable && $view->id() === 'vagas')
        || str_contains($form_dom_id, 'views-exposed-form-vagas-page-1');

    if (!$is_vagas_form || !isset($form['cursos'])) {
        return;
    }

    $search = trim((string) \Drupal::request()->query->get('cursos', ''));
    if ($search !== '') {
        $user_input = $form_state->getUserInput();
        $user_input['cursos'] = '';
        $form_state->setUserInput($user_input);
    }

    unset(
        $form['cursos']['#autocomplete_path'],
        $form['cursos']['#autocomplete_route_name'],
        $form['cursos']['#autocomplete_route_parameters'],
        $form['cursos']['#selection_handler'],
        $form['cursos']['#selection_settings'],
        $form['cursos']['#tags']
    );

    if (isset($form['cursos']['#attributes']['class']) && is_array($form['cursos']['#attributes']['class'])) {
        $form['cursos']['#attributes']['class'] = array_values(array_diff(
            $form['cursos']['#attributes']['class'],
            ['form-autocomplete', 'ui-autocomplete-input']
        ));
    }

    $form['cursos']['#type'] = 'textfield';
    $form['cursos']['#title'] = t('Cursos');
    $form['cursos']['#default_value'] = $search;
    $form['cursos']['#description'] = '';
    $form['cursos']['#attributes']['autocomplete'] = 'off';
    $form['cursos']['#attributes']['placeholder'] = t('Digite um curso');
}

/**
 * Implements hook_views_pre_view().
 *
 * Neutraliza a validação rígida do filtro exposto de taxonomia quando o
 * usuário pesquisa por texto livre no campo cursos.
 */
function custom_panel_views_pre_view(ViewExecutable $view, $display_id, array &$args): void
{
    if ($view->id() !== 'vagas' || $display_id !== 'page_1') {
        return;
    }

    $search = trim((string) \Drupal::request()->query->get('cursos', ''));
    if ($search === '') {
        return;
    }

    $view->build_info['custom_panel_course_search'] = $search;

    $exposed_input = $view->getExposedInput();
    $exposed_input['cursos'] = '';
    $view->setExposedInput($exposed_input);
    $view->exposed_raw_input['cursos'] = '';

    if (isset($view->filter['field_cursos_t_target_id'])) {
        $view->filter['field_cursos_t_target_id']->value = [];
    }
}

/**
 * Implements hook_views_query_alter().
 *
 * Aplica busca por contains no nome dos termos de taxonomia usados no campo
 * de cursos da vaga.
 */
function custom_panel_views_query_alter(ViewExecutable $view, $query): void
{
    if (!$query instanceof Sql || $view->id() !== 'vagas' || $view->current_display !== 'page_1') {
        return;
    }

    $search = trim((string) \Drupal::request()->query->get('cursos', ($view->build_info['custom_panel_course_search'] ?? '')));
    if ($search === '') {
        return;
    }

    $like = '%' . \Drupal::database()->escapeLike($search) . '%';

    $query->addWhereExpression(
        0,
        "EXISTS (
            SELECT 1
            FROM {node__field_cursos_t} nfc
            INNER JOIN {taxonomy_term_field_data} tfd ON tfd.tid = nfc.field_cursos_t_target_id
            WHERE nfc.entity_id = node_field_data.nid
              AND LOWER(tfd.name) LIKE LOWER(:custom_panel_course_search)
        )",
        [':custom_panel_course_search' => $like]
    );
}

function custom_panel_preprocess_page(array &$variables): void
{
    $current_path = \Drupal::service('path.current')->getPath();
    $path_alias = \Drupal::service('path_alias.manager')->getAliasByPath($current_path);
    $is_painel_route = ($current_path === '/painel' || str_starts_with($current_path, '/painel/') || $path_alias === '/painel' || str_starts_with($path_alias, '/painel/'));

    $variables['is_painel_route'] = $is_painel_route;

    if ($is_painel_route) {
        $variables['container'] = 'container-full';
        $variables['#attached']['library'][] = 'default/script-painel';
    }
}

/**
 * Implements hook_theme().
 */
function custom_panel_theme(): array
{
    return [
        'custom_panel_page_header' => [
            'variables' => [
                'title'      => NULL,
                'role_label' => NULL,
                'painel_url' => NULL,
            ],
        ],
        'custom_panel_vagas_salvas' => [
            'variables' => [
                'rows' => [],
                'empty' => NULL,
            ],
        ],
        'custom_panel_vagas_aplicadas' => [
            'variables' => [
                'rows' => [],
                'empty' => NULL,
            ],
        ],
        'custom_panel_moderador_candidaturas' => [
            'variables' => [
                'rows'           => [],
                'empty'          => NULL,
                'status_options' => [],
                'update_url'     => NULL,
            ],
        ],
        'custom_panel_empresa_candidaturas' => [
            'variables' => [
                'rows'  => [],
                'empty' => NULL,
            ],
        ],
    ];
}

/**
 * Implements hook_preprocess_pager().
 *
 * Remove os botões "Primeira página" e "Última página" na listagem de vagas salvas.
 */
function custom_panel_preprocess_pager(array &$variables): void
{
    $route = \Drupal::routeMatch()->getRouteName();
    if (in_array($route, [
        'custom_panel.vagas_salvas_listagem',
        'custom_panel.vagas_aplicadas_listagem',
        'custom_panel.moderador_candidaturas_listagem',
        'custom_panel.empresa_candidaturas_listagem',
    ])) {
        unset($variables['items']['first']);
        unset($variables['items']['last']);
    }
}

/**
 * Implements hook_mail().
 *
 * Define os e-mails enviados pelo módulo custom_panel.
 */
function custom_panel_mail(string $key, array &$message, array $params): void
{
    $site_name = \Drupal::config('system.site')->get('name');

    switch ($key) {
        case 'candidatura_confirmacao':
            $message['subject'] = t('@site — Sua candidatura foi recebida!', ['@site' => $site_name]);
            $message['body'][]  = t('Olá, @nome!', ['@nome' => $params['candidato_nome']]);
            $message['body'][]  = t(
                'Recebemos sua candidatura para a vaga "@vaga". Sua inscrição está em triagem e nossa equipe irá analisar seu perfil em breve.',
                ['@vaga' => $params['vaga_titulo']]
            );
            $message['body'][]  = t('Você pode acompanhar o andamento acessando seu painel em: @url', ['@url' => $params['vaga_url']]);
            $message['body'][]  = t('Atenciosamente,') . "\n" . $site_name;
            break;

        case 'candidatura_status_alterado':
            $message['subject'] = t('@site — Atualização na sua candidatura', ['@site' => $site_name]);
            $message['body'][]  = t('Olá, @nome!', ['@nome' => $params['candidato_nome']]);
            $message['body'][]  = t(
                'O status da sua candidatura para a vaga "@vaga" foi atualizado para: @status.',
                ['@vaga' => $params['vaga_titulo'], '@status' => $params['status_label']]
            );
            $message['body'][]  = t('Acesse a vaga para mais detalhes: @url', ['@url' => $params['vaga_url']]);
            $message['body'][]  = t('Atenciosamente,') . "\n" . $site_name;
            break;
    }
}

/**
 * Implements hook_node_insert().
 *
 * Exibe o número gerado da vaga após o cadastro.
 */
function custom_panel_node_insert(EntityInterface $node): void
{
    if ($node->bundle() !== 'vagas') {
        return;
    }

    \Drupal::messenger()->addStatus(t('Número da Vaga gerado: @numero.', [
        '@numero' => $node->id(),
    ]));
}

/**
 * Implements hook_node_update().
 *
 * Envia e-mail ao candidato quando o status da candidatura for alterado.
 */
function custom_panel_node_update(EntityInterface $node): void
{
    if ($node->bundle() !== 'candidatura') {
        return;
    }

    $new_status = $node->get('field_candidatura_status')->value;
    $old_status = $node->original->get('field_candidatura_status')->value;

    if ($new_status === $old_status) {
        return;
    }

    $status_labels = [
        'em_triagem'          => t('Em Triagem'),
        'aprovado'            => t('Aprovado'),
        'reprovado'           => t('Reprovado'),
        'lista_espera'        => t('Lista de Espera'),
        'entrevista_agendada' => t('Entrevista Agendada'),
    ];

    $candidatos = $node->get('field_candidatura_candidato')->referencedEntities();
    $vagas      = $node->get('field_candidatura_vaga')->referencedEntities();

    /** @var \Drupal\user\UserInterface|null $candidato */
    $candidato = !empty($candidatos) ? $candidatos[0] : NULL;
    $vaga      = !empty($vagas) ? $vagas[0] : NULL;

    if (!$candidato || !$vaga || empty($candidato->getEmail())) {
        return;
    }

    $params = [
        'candidato_nome' => $candidato->getDisplayName(),
        'vaga_titulo'    => $vaga->label(),
        'vaga_url'       => $vaga->toUrl('canonical', ['absolute' => TRUE])->toString(),
        'status_label'   => $status_labels[$new_status] ?? $new_status,
    ];

    \Drupal::service('plugin.manager.mail')->mail(
        'custom_panel',
        'candidatura_status_alterado',
        $candidato->getEmail(),
        $candidato->getPreferredLangcode(),
        $params
    );
}
