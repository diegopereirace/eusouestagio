<?php

/**
 * Implements hook_webform_submission_form_alter().
 */
function custom_configs_webform_submission_form_alter(array &$form, \Drupal\Core\Form\FormStateInterface $form_state, string $form_id): void {
  if ($form['#webform_id'] === 'contato') {
    $form['#attached']['library'][] = 'default/masks';
  }
}
