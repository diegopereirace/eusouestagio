{#
/**
 * @file
 * Listagem de vagas salvas pelo estudante.
 *
 * Variables:
 * - rows: Array de vagas salvas, cada uma com 'title', 'url' e 'date'.
 * - empty: Mensagem exibida quando não há vagas salvas.
 */
#}
<div class="vagas-salvas pt-3 pb-5">  {# padding e min-height definidos em css-painel.css #}
  {% if rows is not empty %}
    <div class="card">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-striped table-hover mb-0">
            <thead>
              <tr>
                <th class="px-4 py-3">{{ 'Vaga'|t }}</th>
                <th class="px-4 py-3 text-nowrap">{{ 'Data de Salvamento'|t }}</th>
              </tr>
            </thead>
            <tbody>
              {% for row in rows %}
                <tr>
                  <td class="px-4 py-3">
                    <a href="{{ row.url }}">{{ row.title }}</a>
                  </td>
                  <td class="px-4 py-3 text-nowrap text-muted small align-middle">{{ row.date }}</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
    {{ pager }}
  {% else %}
    <div class="card">
      <div class="card-body text-center py-5">
        <i class="fa-regular fa-bookmark fa-3x text-muted mb-3 d-block"></i>
        <p class="text-muted mb-3">{{ empty }}</p>
        <a href="/vagas" class="btn btn-primary btn-sm">{{ 'Buscar Vagas'|t }}</a>
      </div>
    </div>
  {% endif %}
</div>
