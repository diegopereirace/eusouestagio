<?php

use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_theme().
 */
function custom_configs_users_theme(): array {
    return [
        'candidato_perfil' => [
            'variables' => [
                'dados'        => [],
                'instituicoes' => [],
                'cursos'       => [],
                'experiencias' => [],
                'user'         => NULL,
            ],
        ],
        'empresa_perfil' => [
            'variables' => [
                'dados' => [],
                'user'  => NULL,
            ],
        ],
    ];
}

/**
 * Implements hook_form_user_form_alter().
 */
function custom_configs_users_form_user_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
    $pass_reset_token = \Drupal::request()->query->get('pass-reset-token');
    $translation = \Drupal::translation();

    if (!$pass_reset_token) {
        return;
    }

    $allowed_top_level = [
        'account',
        'actions',
        'form_build_id',
        'form_token',
        'form_id',
        'op',
        '#attributes',
        '#cache',
        '#theme',
        '#attached',
        '#tree',
        '#parents',
        '#submit',
        '#validate',
        '#method',
        '#action',
        '#token',
        '#id',
    ];

    foreach ($form as $key => &$element) {
        if (strpos((string) $key, '#') === 0) {
            continue;
        }

        if (is_array($element) && (($element['#type'] ?? NULL) === 'hidden')) {
            continue;
        }

        if (!in_array($key, $allowed_top_level, TRUE)) {
            $element['#access'] = FALSE;
        }
    }

    if (isset($form['account']) && is_array($form['account'])) {
        foreach ($form['account'] as $key => &$element) {
            if (strpos((string) $key, '#') === 0) {
                continue;
            }

            if ($key !== 'pass') {
                $element['#access'] = FALSE;
            }
        }

        $form['account']['reset_help'] = [
            '#type' => 'markup',
            '#markup' => '<div class="alert alert-info mb-3">' . $translation->translate('Defina uma nova senha para concluir o acesso da sua conta.') . '</div>',
            '#weight' => -100,
        ];
    }

    if (isset($form['actions']['submit'])) {
        $form['actions']['submit']['#value'] = $translation->translate('Definir senha');
        $form['actions']['submit']['#submit'][] = 'custom_configs_users_user_pass_reset_submit';
    }
}

/**
 * Submit callback for password reset with token.
 */
function custom_configs_users_user_pass_reset_submit(array &$form, FormStateInterface $form_state) {
    $pass_reset_token = \Drupal::request()->query->get('pass-reset-token');

    if (!$pass_reset_token) {
        return;
    }

    $account = \Drupal::routeMatch()->getParameter('user');
    if (is_numeric($account)) {
        $account = \Drupal\user\Entity\User::load($account);
    }

    \Drupal::messenger()->addStatus(\Drupal::translation()->translate('Senha definida com sucesso. Bem-vindo(a)!'));

    if ($account && method_exists($account, 'hasRole') && $account->hasRole('empresa')) {
        $form_state->setRedirect('custom_configs_users.empresa_perfil');
        return;
    }

    if ($account && method_exists($account, 'hasRole') && $account->hasRole('candidato')) {
        $form_state->setRedirect('custom_configs_users.candidato_perfil');
        return;
    }

    $form_state->setRedirect('<front>');
}
